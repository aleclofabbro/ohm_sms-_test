{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "types": ["jest", "node"],
    "esModuleInterop": true,
    "allowJs": true,
    "checkJs": false,
    "moduleResolution": "nodenext",
    "module": "nodenext"
  },
  "include": [
    "src/**/*.ts",
    "src/**/*.test.ts",
    "src/**/*.test.tsx"
  ]
}