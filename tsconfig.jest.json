{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "composite": true,
    "target": "esnext",
    "types": ["jest", "node"],
    "esModuleInterop": true,
    "allowJs": true,
    "checkJs": false,
    "moduleResolution": "bundler",
    "module": "esnext"
  },
  "include": ["src/**/*.ts", "src/**/*.node.ts", "src/**/*.test.ts", "src/**/*.test.tsx"]
}